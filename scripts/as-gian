#!/usr/bin/env bash
# Switch this repo's commit identity to Gianluca (repo-local only).
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
git config user.name "Gianluca Fonseca"
git config user.email "76885401+gianluca-fonseca@users.noreply.github.com"
echo "This repo now commits as: Gianluca Fonseca <76885401+gianluca-fonseca@users.noreply.github.com>"
