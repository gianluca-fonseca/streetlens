# Copy to `.env.local` and fill in values. Never commit `.env.local`.
# Placeholders only — no real secrets.

# --- Public map / Supabase read path ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Demo data switch (must be exactly "true" to publish pilot scores) ---
NEXT_PUBLIC_SHOW_DEMO_DATA=

# --- Admin auth ---
ADMIN_PASSWORD=
ADMIN_RPC_SECRET=

# --- Private frame signing (0028; required for admin review + extraction pump) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Anonymous intake ---
SUBMISSIONS_IP_SALT=

# --- CV extraction (see docs/cv-funnel.md) ---
OPENAI_API_KEY=
OPENAI_VISION_MODEL=
OPENAI_VISION_ESCALATION_MODEL=
OPENAI_SYNTHESIS_MODEL=
CV_EXTRACTION_ENABLED=
CV_SYNTHESIS_MAX_ADJUST=
CV_SYNTHESIS_MAX_OUTPUT_TOKENS=
CV_INPUT_TOKEN_CEILING=
CV_SESSION_TOKENS_PER_FRAME=

# --- Scheduled pump (Vercel Cron) ---
CRON_SECRET=

# --- Test isolation (optional; CI sets automatically) ---
STREETLENS_DATA_DIR=
