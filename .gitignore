# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*.local
.env*

# vercel
.vercel/

# typescript
*.tsbuildinfo
next-env.d.ts
.planning/evidence/dev-server.log

# admin runtime submission data (u3 queue + local review overlay/staging)
/data/pending-submissions.local.json
/data/submission-reviews.local.json
/data/approved-submissions.local.json

# community-apply local store (u7 apply pipeline, DB fallback; never committed)
/data/community-segments.local.json
/data/community-reports.local.json

# transient tsc→cjs build dirs used by the node test/smoke scripts
/.smoke-build/
/.test-build-*/
  # Local anonymous-submission queue (DB fallback; never committed)
data/pending-submissions.local.json
